<?xml version="1.0" encoding="UTF-8"?>
<theme-data>
	<name>Default</name>
	<background-color>#202020ff</background-color>
	<highlights>
		<rule>
			<regex>([0-9]+|cout)</regex>
			<color>#e2f000ff</color>
		</rule>
		<rule>
			<regex>\".*\"</regex>
			<color>#e7f700ff</color>
		</rule>
		<rule>
			<regex>(int|void|char|using|bool)</regex>
			<color>#005bd1ff</color>
		</rule>
		<rule>
			<regex>(namespace|main)</regex>
			<color>#d17300</color>
		</rule>
		<rule>
			<regex>(\breturn\b|\bif\b|\bwhile\b|\bfor\b|\bdo\b|\bconst\b)</regex>
			<color>#ac7700ff</color>
		</rule>
		<rule>
			<regex>[\[\](){}&lt;&gt;]</regex>
			<color>#8a8a8a</color>
		</rule>
		<rule>
			<regex>(\bstd\b|\bstring\b)</regex>
			<color>#50a579ff</color>
		</rule>
		<rule>
			<regex>(\/\/.*)|(\/\*[\s\S]*?\*\/)</regex>
			<color>#235530ff</color>
		</rule>
		<rule>
			<regex>#include\s*&lt;.*&gt;</regex>
			<color>#d17300ff</color>
		</rule>
	</highlights>
</theme-data>
